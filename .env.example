# ---- Core ----
# PostgreSQL. Get a free one in 30s at https://neon.tech (copy the pooled URL).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Public URL used to build shareable report links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Auth ----
# 32+ char random string. Used to sign iron-session cookies.
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# ---- Storage ----
# "local" stores uploads in /public/uploads. Swap for "s3" in production.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./public/uploads"
# S3 placeholders (required when STORAGE_DRIVER=s3)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ---- Maps & Geocoding ----
# Nominatim (OSM) is used by default and requires no key. Swap to Mapbox/Google for prod.
GEOCODER_PROVIDER="nominatim"
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
MAPBOX_ACCESS_TOKEN=""
GOOGLE_MAPS_API_KEY=""

# ---- External data connectors ----
# All connectors ship with stub implementations so the app runs end-to-end without these.
# Provide real endpoints/keys to activate production connectors.
SEPOMEX_API_URL=""
SEPOMEX_API_KEY=""

SEDUVI_API_URL=""
SEDUVI_API_KEY=""

INEGI_API_URL="https://www.inegi.org.mx/app/api/denue/v1/consulta"
# Free token — register at: https://www.inegi.org.mx/app/desarrolladores/generatoken/Usuarios/token_Verify
# When set, enrichment uses real DENUE data for commercial context.
# When empty, falls back to OpenStreetMap Overpass (also real, but less complete for MX).
INEGI_API_TOKEN=""

COMMERCIAL_API_URL=""
COMMERCIAL_API_KEY=""

# ---- Queue ----
# "inline" runs jobs in the request lifecycle (dev default). Swap to "bullmq" + REDIS_URL in prod.
QUEUE_DRIVER="inline"
REDIS_URL=""

# ---- PDF ----
# "puppeteer" uses local chromium. Swap for a remote rendering service in prod.
PDF_DRIVER="puppeteer"
